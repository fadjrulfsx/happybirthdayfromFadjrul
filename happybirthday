<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>HAPPY BIRTHDAY</title>
  <style>
    :root{
      --bg1: #fff0f6;
      --bg2: #ffe6f0;
      --accent: #d81b60;
      --cake1: #ff9fb1;
      --cake2: #ffd1e8;
      --cake3: #ff7aa2;
      --cream: #fff7f9;
      --candle: #fff176;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family: "Poppins", system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
      background: linear-gradient(120deg,var(--bg1),var(--bg2));
      display:flex;
      align-items:center;
      justify-content:center;
      flex-direction:column;
      overflow:hidden;
      color:#333;
    }

    h1{
      margin:24px 0 8px;
      font-size:2.2rem;
      color:var(--accent);
      letter-spacing:0.5px;
    }
    p.lead{
      margin:0 0 18px;
      opacity:0.85;
    }

    /* Scene container */
    .stage{
      width:360px;
      max-width:92vw;
      position:relative;
      display:flex;
      align-items:flex-end;
      justify-content:center;
      padding-bottom:40px;
    }

    /* Cake wrapper */
    .cake{
      width:260px;
      position:relative;
      display:flex;
      align-items:flex-end;
      justify-content:center;
      flex-direction:column;
      gap:8px;
      transform-origin:center bottom;
    }

    /* Each layer */
    .layer{
      width:260px;
      height:56px;
      border-radius:18px;
      box-shadow:0 8px 18px rgba(0,0,0,0.12);
      position:relative;
      overflow:visible;
      transform: translateY(-220px) scale(0.98);
      opacity:0;
      transition: transform 700ms cubic-bezier(.2,.9,.3,1), opacity 700ms ease;
    }
    .layer.layer-1{ background: linear-gradient(180deg,var(--cake1),#ff6f98); width:180px; border-radius:14px; margin:0 auto;}
    .layer.layer-2{ background: linear-gradient(180deg,var(--cake2),#ffc0dd); width:220px; border-radius:16px; margin:0 auto; }
    .layer.layer-3{ background: linear-gradient(180deg,var(--cake3),#ff4f86); width:260px; border-radius:18px; margin:0 auto; }

    /* Cream decorations */
    .cream{
      position:absolute;
      top:-12px;
      left:0;
      right:0;
      height:24px;
      background: repeating-linear-gradient(90deg, rgba(255,255,255,0.95) 0 6px, rgba(255,255,255,0.85) 6px 12px);
      border-radius:12px;
      filter:drop-shadow(0 2px 4px rgba(0,0,0,0.06));
      transform: translateY(-6px);
    }

    /* Candle container positioned above cake */
    .candle-wrap{
      width:100%;
      display:flex;
      justify-content:center;
      align-items:flex-end;
      gap:18px;
      position:relative;
      height:120px;
      pointer-events:none;
    }

    .candle{
      width:12px;
      height:44px;
      background:var(--candle);
      border-radius:4px;
      box-shadow: inset 0 -4px 0 rgba(0,0,0,0.06);
      transform: translateY(-220px);
      opacity:0;
      transition: transform 600ms cubic-bezier(.2,.9,.3,1), opacity 600ms ease;
      position:relative;
      display:flex;
      align-items:flex-start;
      justify-content:center;
    }

    .candle::after{
      content:"";
      position:absolute;
      bottom:6px;
      left:50%;
      transform:translateX(-50%);
      width:6px;
      height:6px;
      background:rgba(0,0,0,0.06);
      border-radius:50%;
    }

    .flame{
      position:absolute;
      top:-18px;
      left:50%;
      transform:translateX(-50%) scale(0.9);
      width:18px;
      height:26px;
      border-radius:50% 50% 50% 50%;
      background: radial-gradient(circle at 40% 30%, #fff59d 0 20%, #ffd54a 22% 45%, #ff7043 60% 100%);
      filter:drop-shadow(0 6px 8px rgba(255,140,0,0.12));
      opacity:0;
      transition: opacity 300ms ease, transform 300ms ease;
      animation: flicker 360ms infinite alternate;
      pointer-events:none;
    }

    @keyframes flicker{
      from{ transform:translateX(-50%) scale(1); opacity:1 }
      to{ transform:translateX(-50%) scale(1.18); opacity:0.85 }
    }

    /* Plate */
    .plate{
      width:320px;
      height:12px;
      transform: translateX(30px);
      background: linear-gradient(180deg,#fff,#f3f3f3);
      border-radius:50%;
      margin-top:-10px;
      box-shadow:0 6px 18px rgba(0,0,0,0.08);
    }

    /* Button */
    .controls{ margin-top:18px; display:flex; gap:12px; align-items:center; }
    button.primary{
      background:var(--accent);
      color:#fff;
      border:none;
      padding:10px 16px;
      border-radius:10px;
      cursor:pointer;
      font-weight:600;
      box-shadow:0 8px 18px rgba(216,27,96,0.18);
    }
    button.ghost{
      background:transparent;
      border:1px solid rgba(0,0,0,0.08);
      padding:8px 12px;
      border-radius:10px;
      cursor:pointer;
    }

    /* Confetti pieces */
    .confetti{
      position:fixed;
      width:12px;
      height:18px;
      opacity:1;
      transform-origin:center;
      will-change: transform, opacity;
      z-index:9999;
      pointer-events:none;
      border-radius:3px;
    }

    /* small sparkle */
    .sparkle{
      position:absolute;
      width:8px;
      height:8px;
      background:rgba(255,255,255,0.9);
      border-radius:50%;
      filter:blur(0.6px);
      opacity:0;
      transform:scale(0.6);
      transition:opacity 300ms ease, transform 300ms ease;
      pointer-events:none;
    }

    /* Responsive */
    @media (max-width:420px){
      .cake{ width:86vw }
      .layer{ width:86vw }
      .plate{ width:96vw }
    }
    .popup-overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.6);
      display: none; /* awalnya disembunyikan */
      justify-content: center;
      align-items: center;
    }

    /* Popup box */
    .popup-box {
      background: white;
      padding: 20px;
      border-radius: 10px;
      text-align: center;
      max-width: 300px;
      box-shadow: 0 0 15px rgba(0,0,0,0.3);
      animation: fadeIn 0.5s ease;
    }

    .popup-box h2 { color: #d81b60; }
    .popup-box p { margin: 10px 0; }

    .popup-box button {
      background: #d81b60; color: white;
      border: none;
      padding: 8px 15px;
      border-radius: 5px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <h1>HAPPY BIRTHDAY TWIN</h1>
  <p class="lead">Tekan tombol untuk memulai animasi kue dan pesta confetti</p>

  <div class="stage">
    <div class="cake" id="cake">
      <div class="candle-wrap" id="candleWrap">
        <!-- Candles will be injected by JS for nicer spacing -->
      </div>

      <!-- Layers stacked bottom to top visually but will animate in -->
      <div class="layer layer-1" id="layer1">
        <div class="cream"></div>
      </div>
      <div class="layer layer-2" id="layer2">
        <div class="cream"></div>
      </div>
      <div class="layer layer-3" id="layer3">
        <div class="cream"></div>
      </div>

      <div class="plate" aria-hidden="true"></div>
    </div>
  </div>

  <div class="controls">
    <button class="primary" id="startBtn">Mulai Animasi</button>
    <button class="ghost" id="resetBtn">Reset</button>
  </div>
  <button onclick="showPopup()">Klik untuk kejutan</button>
  <div class="popup-overlay" id="popup">
    <div class="popup-box">
      <h2>Selamat Ulang Tahun!</h2>
      <p>"Selamat ulang tahun lutfa Semoga Allah selalu melimpahkan kesehatan, kebahagiaan, dan keberkahan dalam setiap langkahmu.
         Semoga cita-citamu tercapai, dan hatimu selalu dipenuhi ketenangan serta cinta dari orang-orang terdekat."</p>
         <p>SEMOGA NANTI PAS MIMPI KAMU KETEMU YOUR WIFE KENYU</p>
      <button onclick="closePopup()">Tutup</button>
    </div>
  </div>

  <!-- Audio efek -->
  <audio id="cheerSound" src="https://www.soundjay.com/human/cheering-01.mp3" preload="auto"></audio>

  <script>
    function showPopup() {
      document.getElementById("popup").style.display = "flex";
    }
    function closePopup() {
      document.getElementById("popup").style.display = "none";
    }
    // Elements
    const startBtn = document.getElementById('startBtn');
    const resetBtn = document.getElementById('resetBtn');
    const layers = [document.getElementById('layer1'), document.getElementById('layer2'), document.getElementById('layer3')];
    const candleWrap = document.getElementById('candleWrap');
    const cheer = document.getElementById('cheerSound');

    // Create candles dynamically and place above cake center
    function createCandles(count = 3){
      candleWrap.innerHTML = '';
      const spacing = 40;
      const totalWidth = (count - 1) * spacing;
      for(let i=0;i<count;i++){
        const c = document.createElement('div');
        c.className = 'candle';
        c.style.left = `calc(50% - ${totalWidth/2}px + ${i*spacing}px)`;
        c.style.position = 'absolute';
        // flame inside candle
        const f = document.createElement('div');
        f.className = 'flame';
        c.appendChild(f);
        candleWrap.appendChild(c);
      }
    }

    // Reset visuals to initial state
    function resetScene(){
      // hide layers and candles
      document.querySelectorAll('.layer').forEach(l=>{
        l.style.opacity = 0;
        l.style.transform = 'translateY(-220px) scale(0.98)';
      });
      document.querySelectorAll('.candle').forEach(c=>{
        c.style.opacity = 0;
        c.style.transform = 'translateY(-220px)';
        const flame = c.querySelector('.flame');
        if(flame) flame.style.opacity = 0;
      });
      // remove confetti if any
      document.querySelectorAll('.confetti').forEach(n=>n.remove());
      // stop audio
      try{ cheer.pause(); cheer.currentTime = 0; }catch(e){}
    }

    // Animate sequence: candle first, then layers drop one by one, then confetti + sound
    async function playSequence(){
      startBtn.disabled = true;
      resetBtn.disabled = true;

      // show candles
      const candles = document.querySelectorAll('.candle');
      candles.forEach((c,i)=>{
        setTimeout(()=>{
          c.style.opacity = 1;
          c.style.transform = 'translateY(0)';
        }, i * 120);
      });

      // show flames shortly after candles
      setTimeout(()=>{
        document.querySelectorAll('.flame').forEach((f,i)=>{
          setTimeout(()=> f.style.opacity = 1, i*80);
        });
      }, 400);

      // drop layers from top to bottom visually (top layer appears last)
      for(let i=layers.length-1;i>=0;i--){
        await delay(700); // wait between each layer
        layers[i].style.opacity = 1;
        layers[i].style.transform = 'translateY(0) scale(1)';
        // small sparkle on layer
        createSpark(layers[i]);
      }

      // short pause then confetti + sound
      await delay(600);
      launchConfettiBurst();
      try{ cheer.currentTime = 0; cheer.play(); }catch(e){}

      // re-enable reset
      setTimeout(()=>{ startBtn.disabled = false; resetBtn.disabled = false; }, 1200);
    }

    // Utility delay
    function delay(ms){ return new Promise(res=>setTimeout(res,ms)); }

    // Create a small sparkle on a target element
    function createSpark(target){
      const s = document.createElement('div');
      s.className = 'sparkle';
      s.style.left = (target.clientWidth/2 - 4) + 'px';
      s.style.top = '-6px';
      target.appendChild(s);
      // animate
      requestAnimationFrame(()=> {
        s.style.opacity = 1;
        s.style.transform = 'scale(1.6)';
      });
      setTimeout(()=> {
        s.style.opacity = 0;
        s.style.transform = 'scale(0.6)';
        setTimeout(()=> s.remove(), 400);
      }, 420);
    }

    // Confetti burst from left-bottom and right-bottom with randomized trajectories
    function launchConfettiBurst(){
      const total = 80;
      for(let i=0;i<total;i++){
        const el = document.createElement('div');
        el.className = 'confetti';
        // random shape color
        el.style.background = randomColor();
        // start from left or right bottom
        const fromLeft = Math.random() < 0.5;
        const startX = fromLeft ? (Math.random() * 120) : (window.innerWidth - (Math.random() * 120) - 12);
        const startY = window.innerHeight - 8;
        el.style.left = startX + 'px';
        el.style.top = startY + 'px';
        // random size and rotation
        const w = 8 + Math.random()*12;
        const h = 8 + Math.random()*18;
        el.style.width = w + 'px';
        el.style.height = h + 'px';
        el.style.borderRadius = (Math.random() > 0.6 ? '3px' : '50%');
        document.body.appendChild(el);

        // compute random trajectory
        const angle = (fromLeft ? (Math.random()*0.6 + 0.2) : (Math.random()*-0.6 - 0.2)); // radians-ish for x offset
        const distanceY = 0.45*window.innerHeight + Math.random()*0.35*window.innerHeight;
        const distanceX = (Math.random()*0.6 + 0.4) * window.innerWidth * (fromLeft ? 0.35 : -0.35);
        const duration = 900 + Math.random()*900; // faster pieces and variety

        // animate using JS for better control
        const start = performance.now();
        const rotateSpeed = (Math.random()*720 - 360);
        (function animate(now){
          const t = Math.min(1, (now - start) / duration);
          // ease out cubic
          const ease = 1 - Math.pow(1 - t, 3);
          const curX = startX + distanceX * ease;
          const curY = startY - distanceY * ease;
          el.style.transform = `translate(${curX - startX}px, ${curY - startY}px) rotate(${rotateSpeed * ease}deg)`;
          el.style.opacity = String(1 - ease);
          if(t < 1) requestAnimationFrame(animate);
          else el.remove();
        })(start);
      }
    }

    // Random color helper
    function randomColor(){
      const palette = ['#ff4081','#3f51b5','#4caf50','#ffeb3b','#ff5722','#00bcd4','#9c27b0'];
      return palette[Math.floor(Math.random()*palette.length)];
    }

    // Event listeners
    startBtn.addEventListener('click', async ()=>{
      // create 3 candles by default
      createCandles(3);
      resetScene();
      await delay(80);
      playSequence();
    });

    resetBtn.addEventListener('click', ()=>{
      resetScene();
    });

    // initialize
    createCandles(3);
    resetScene();
  </script>
</body>
</html>
